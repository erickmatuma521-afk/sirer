# --- Supabase (PostgreSQL) ---
# Dans le dashboard Supabase : Settings > Database
# 1) URI "Transaction pooler" (port 6543, mode session) -> DATABASE_URL
#    Ajoutez souvent : ?pgbouncer=true&connection_limit=1
# 2) URI "Direct connection" (port 5432) -> DIRECT_URL (obligatoire pour prisma migrate)
#
# Exemple (à adapter avec votre projet) :
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres.enctafqqpxhaemwdihoq:[@Cosmas3108]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.enctafqqpxhaemwdihoq:[@Cosmas3108]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

JWT_SECRET=changez-moi-en-production-minimum-32-caracteres
ENCRYPTION_KEY=changez-cle-32-octets-pour-aes-256!!
PORT=3001

# Origine(s) du frontend (Vercel). Plusieurs URLs séparées par des virgules :
# FRONTEND_URL=https://votre-app.vercel.app,https://votre-app-git-main-xxx.vercel.app
FRONTEND_URL=http://localhost:5173
