# --- Supabase (PostgreSQL) ---
# Dashboard Supabase : Settings > Database > Connection string
#
# 1) DATABASE_URL (runtime / Vercel) : « Transaction pooler » (port 6543, host …pooler.supabase.com)
#    Paramètres recommandés pour Prisma + serverless :
#    ?pgbouncer=true&connection_limit=1&sslmode=require
#
# 2) DIRECT_URL (migrations locales / CI) : « Direct connection » (host db.xxxxx.supabase.co, port 5432)
#    Pas le pooler transaction (6543) — pour `prisma migrate` / introspection.

# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[MOT_DE_PASSE]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[MOT_DE_PASSE]@db.[PROJECT_REF].supabase.co:5432/postgres?sslmode=require"

DATABASE_URL=
DIRECT_URL=

JWT_SECRET=changez-moi-en-production-minimum-32-caracteres
ENCRYPTION_KEY=changez-cle-32-octets-pour-aes-256!!
PORT=3001

# Origine(s) du frontend (Vercel). Plusieurs URLs séparées par des virgules :
# FRONTEND_URL=https://votre-app.vercel.app,https://votre-app-git-main-xxx.vercel.app
FRONTEND_URL=http://localhost:5173
